datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model Receipt {
  id            Int      @id @default(autoincrement())
  serial        String   @unique
  vehicleNumber String
  amount        String
  driverName    String
  issuedAt      DateTime
  status        String
  createdAt     DateTime @default(now())
}
